---
/**
 * Main page — assembles all sections in order.
 */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.svelte";
import HeroSection from "../components/HeroSection.svelte";
import CatalogSection from "../components/CatalogSection.astro";
import TechnologiesSection from "../components/TechnologiesSection.astro";
import QualitySection from "../components/QualitySection.astro";
import TestimonialsSection from "../components/TestimonialsSection.svelte";
import ContactUsSection from "../components/ContactUsSection.astro";
import Footer from "../components/Footer.astro";

import { greens, microgreens } from "../data/site";
---

<Layout>
  <Header client:load />

  <main class="flex flex-col pt-16 *:scroll-mt-16">
    <HeroSection client:load />

    <CatalogSection catalog={greens} />
    <CatalogSection catalog={microgreens} />

    <TestimonialsSection client:visible />

    <TechnologiesSection />
    <QualitySection />

    <ContactUsSection />
  </main>

  <Footer />
</Layout>