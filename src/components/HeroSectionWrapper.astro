---
/**
 * Hero section wrapper — provides the <section> element for CSS nth-of-type.
 *
 * WHY THIS EXISTS:
 * Svelte components rendered with client:load are wrapped in <astro-island>
 * by Astro. This makes the Svelte component's content a grandchild of <main>,
 * not a direct child. CSS `main > section` wouldn't match it.
 *
 * SOLUTION:
 * This Astro wrapper provides <section> as a direct child of <main>.
 * The Svelte component renders inside, wrapped by <astro-island>.
 *
 * The <section> also provides the container width and padding,
 * so the Svelte component only needs to handle its internal layout.
 *
 * client:load: hydrate immediately (hero is above the fold).
 */
import HeroSection from "./HeroSection.svelte";
---

<!-- id="home" is the anchor target for the logo link and #home hrefs -->
<section id="home" class="flex-1">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <HeroSection client:load />
  </div>
</section>