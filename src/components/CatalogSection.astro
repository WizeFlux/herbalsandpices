---
/**
 * Reusable catalog section — renders greens or microgreens.
 * Pure declarative: data in, cards out, no client JS.
 */
import type { CatalogSection } from "../data/site";
import { asset } from "../data/site";

interface Props {
  catalog: CatalogSection;
}

const { catalog } = Astro.props;
---

<section
  id={catalog.id}
  class="relative py-8 before:absolute before:inset-0 before:-z-10 before:-skew-y-3 before:bg-muted sm:py-16 lg:py-24"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 flex max-w-2xl flex-col items-center space-y-1 text-center sm:mb-16 lg:mb-24">
      <h2 class="text-2xl font-semibold md:text-3xl lg:text-4xl">{catalog.name}</h2>
      <p class="text-xl text-muted-foreground">{catalog.text}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:gap-y-10 xl:grid-cols-4">
      {catalog.items.map((item) => (
        <article
          class="overflow-hidden border transition-colors duration-300 hover:border-primary"
        >
          <div class="bg-muted">
            <img src={asset(item.image)} alt={item.alt} class="h-auto w-full" loading="lazy" />
          </div>
          <div class="space-y-3 px-6 py-5">
            <h3 class="text-lg font-semibold">{item.name}</h3>
            <hr class="border-border" />
            <div class="text-muted-foreground">
              <p class="mb-1 text-base font-medium">{item.type}</p>
              <p>{item.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>