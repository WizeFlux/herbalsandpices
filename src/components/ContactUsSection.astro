---
/**
 * Contact section — call-to-action + contact info cards.
 * Static, no JS needed.
 */
import { contactInfo, asset } from "../data/site";

const iconPaths: Record<string, string> = {
  clock: "M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z",
  phone: "M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z",
  mail: "M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6",
  telegram:
    "M21.5 4.5L2.5 12.5l5.5 2 2 6 3-4 5.5 4 3-16z M10 16l4-4",
};
---

<section
  id="contact-us"
  class="relative"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12">
      <div>
        <h3 class="mb-2 text-3xl">Давайте развивать вкус Шерегеша вместе!</h3>
        <p class="mb-10 text-lg text-muted-foreground">
          Наша ферма находится в 5 минутах от вас. Мы всегда рады гостям и готовы познакомить вас с
          нашей «внутренней кухней». Хотите оценить аромат продукции в своем заведении? Мы
          <strong>бесплатно доставим тестовый набор</strong> прямо на вашу кухню.
        </p>

        <div class="grid gap-6 sm:grid-cols-4">
          {contactInfo.map((info) => (
            <div
              class="flex flex-col items-center gap-4 border bg-background p-6 text-center transition-colors duration-300 hover:border-primary"
            >
              <div class="flex size-9 items-center justify-center border rounded-full">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d={iconPaths[info.icon]} />
                </svg>
              </div>
              <div class="space-y-3">
                <h4 class="text-lg font-semibold">{info.title}</h4>
                <div class="text-base font-medium text-muted-foreground whitespace-pre-line">
                  {info.description}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>